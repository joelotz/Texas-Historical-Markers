    <name>Salem Cemetery</name>
    <description><![CDATA[<b>Address:</b> 9827 Loop 106, Sayers<br/><br/><b>Marker Text:</b> Salem Cemetery Established 1880 Historic Texas Cemetery - 2006]]></description>
    <Point><coordinates>-98.294104,29.375404,0</coordinates></Point>
  </Placemark>
