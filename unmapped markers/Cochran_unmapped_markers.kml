<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
<Document>
  <name>Cochran County — Unmapped Historical Markers</name>
  <description>THC markers in Cochran County without an HMDB id (isMissing excluded). 2 with THC coords; 0 geocoded from address; 2 omitted (no usable address).</description>
  <Placemark>
    <name>First Telephone Office in Cochran County</name>
    <description><![CDATA[206 Southwest 1st Street<br/><br/><b>Address:</b> 206 Southwest 1st Street, Morton<br/><br/><b>Marker Text:</b> Erected 1925 at western terminus of South Plains &amp; Santa Fe Railway in Bledsoe (25 miles southwest), for Texas Telephone Company; moved to Morton in 1926. Outgrown for phone company use in 1949, building became county museum in 1968. Recorded Texas Historic Landmark - 1969]]></description>
    <Point><coordinates>-102.760497,33.724123,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>Smith Office</name>
    <description><![CDATA[116 North Main Street-Morton<br/><br/><b>Address:</b> 116 North Main Street, Morton<br/><br/><b>Marker Text:</b> The Texas Historical Building Medallion included. (destroyed)]]></description>
    <Point><coordinates>-102.75915,33.72547,0</coordinates></Point>
  </Placemark>
</Document>
</kml>
