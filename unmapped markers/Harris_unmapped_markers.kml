  <Placemark>
    <name>Founders' Memorial Park Cemetery</name>
    <description><![CDATA[1217 West Dallas at Valentine Street<br/><br/><b>Address:</b> 1217 West Dallas, Houston<br/><br/><b>Marker Text:</b> Historic Texas Cemetery - 2005]]></description>
