    <Point><coordinates>-98.673542,27.30844,0</coordinates></Point>
  </Placemark>
  <Placemark>
    <name>Lino Ramirez Family Cemetery</name>
    <description><![CDATA[Drive Highway 16 south about 30 miles to FM 649 and turn left, travel about 5 miles to entrance of East Ranch, travel east about 4 miles on private paved road, turn right at caliche road and travel south about 4 miles to Ramirez Windmill. Cemetery lies about 1000 feet south in field surrounded by grove of trees.<br/><br/><b>Address:</b> 474 East Ranch Road, Hebbronville]]></description>
    <Point><coordinates>-98.833077,26.957344,0</coordinates></Point>
  </Placemark>
